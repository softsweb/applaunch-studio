# Node API server port (Dokploy usually injects PORT automatically)
PORT=3000

# PostgreSQL connection string from your Dokploy database service
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# The secret token used by /api/deployments/increment
DEPLOY_HOOK_TOKEN=replace-with-a-long-random-token

# Optional overrides
DEPLOYMENTS_METRIC_KEY=deployments
DEPLOYMENTS_FALLBACK=0
# Set to "require" only if your database requires SSL
PGSSLMODE=disable
